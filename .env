# ============================================================================
# REDIS / CELERY (Windows dev | Linux prod)
# ============================================================================
# Desarrollo (Windows): host local, sin password, DB 0.
# Producción (Linux): define REDIS_URL o CELERY_BROKER_URL con el servicio Redis.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Opcional: una sola URL (tiene prioridad sobre REDIS_HOST/PORT/DB si se define)
# REDIS_URL=redis://:tu_password@redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=

# Sin Redis/worker en dev: ejecuta tareas en el mismo proceso (solo desarrollo)
CELERY_TASK_ALWAYS_EAGER=false

# Sincronización (worker + beat en prod; en dev con eager no hace falta beat)
CELERY_SYNC_MINUTES=1
CELERY_SMARTCARD_SYNC_MINUTES=1
CELERY_SYNC_LIMIT=200
CELERY_SYNC_QUEUE=sync_subscribers

# Full-sync correctivo (Celery Beat, horario bajo tráfico)
CELERY_FULL_SYNC_ENABLED=true
CELERY_FULL_SYNC_HOUR=0
CELERY_FULL_SYNC_MINUTE=0
CELERY_FULL_SYNC_TIME_LIMIT=3600
CELERY_FULL_SYNC_SOFT_TIME_LIMIT=3300
# HTTP manual (solo staff); en prod dejar false
FULL_SYNC_HTTP_ENABLED=false

# Throttling DRF (opcional)
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=600/minute
DRF_THROTTLE_PROFILE=120/minute
DRF_THROTTLE_SYNC_ADMIN=30/minute


