# Copiar a .env y completar valores reales

# --- Django / seguridad (roadmap #3: docs/SEGURIDAD_PRODUCCION_UBUNTU.md) ---
DEBUG=false
SECRET_KEY=genera-con-python-secrets-token_hex-32
ALLOWED_HOSTS=api.tudominio.com,tudominio.com
# Solo con nginx + TLS en Ubuntu (roadmap #5 / #23):
# PRODUCTION_HTTPS=true
# SYNC_HTTP_ASYNC=true
# SYNC_ADMIN_IP_ALLOWLIST=127.0.0.1,10.8.0.0/24
#
# Desarrollo local:
# DEBUG=true
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# o CORS_DEV_DEFAULTS=true
#
# Login social Facebook (HTTPS local): docs/LOGIN_SOCIAL_LOCAL_HTTPS.md
#   .\scripts\setup_local_https.ps1  →  .\scripts\run_local_https.ps1
#   Navegador: https://localhost:8444/wind/login/
# En Google Cloud / Meta: origen https://localhost:8444

# Producción — frontend en otro dominio (roadmap #4):
CORS_ALLOWED_ORIGINS=https://app.tudominio.com,https://www.tudominio.com

# --- Base de datos ---
# Dev (SQLite): no definir DB_ENGINE o dejar vacío
# Staging/prod (PostgreSQL):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=wind
# DB_USER=wind
# DB_PASSWORD=wind
# DB_HOST=localhost
# DB_PORT=5432
# DB_CONN_MAX_AGE=600
# Réplica lectura (Fase 4, opcional):
# DB_REPLICA_HOST=replica-host
# DB_REPLICA_PORT=5432

# --- Redis / Celery (Ubuntu: docs/REDIS_CELERY_UBUNTU.md) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_SYNC_MINUTES=10
CELERY_SMARTCARD_SYNC_MINUTES=10
CELERY_SYNC_LIMIT=200
CELERY_SYNC_QUEUE=sync_subscribers

# --- PanAccess API ---
url_panaccess=
username=
password=
api_token=
salt=
hcId=
ENCRYPTION_KEY=

# --- Sesión PanAccess en Redis (multi-worker) ---
PANACCESS_SESSION_USE_REDIS=true
PANACCESS_SESSION_TTL_SECONDS=1500

# --- Circuit breaker (prod) ---
PANACCESS_CIRCUIT_BREAKER_ENABLED=true
PANACCESS_CB_FAILURE_THRESHOLD=5
PANACCESS_CB_RECOVERY_SECONDS=60

# --- Login info full-sync (#11) ---
PANACCESS_LOGIN_INFO_TRY_LIST_API=true
PANACCESS_LOGIN_INFO_CONCURRENCY=10
PANACCESS_LOGIN_INFO_PAGE_LIMIT=200
PANACCESS_LOGIN_INFO_DB_CHUNK=200

# --- Perfil smartcards (#13) ---
PANACCESS_SMARTCARD_SUBSCRIBER_MAX_PAGES=5
PANACCESS_SMARTCARD_SN_CONCURRENCY=5

# --- Sync / Beat (ver docs/SYNC_FLUJO_TAREAS.md) ---
# Deploy manual 1x: POST sync-subscribers, sync-products, sync-smartcards
# Luego Beat: compare_and_update_subscribers + compare_and_update_smartcards cada N min
CELERY_SYNC_MINUTES=10
CELERY_SMARTCARD_SYNC_MINUTES=10
CELERY_SYNC_LIMIT=200
CELERY_FULL_SYNC_HOUR=0
CELERY_FULL_SYNC_MINUTE=0
CELERY_FULL_SYNC_ENABLED=true
FULL_SYNC_HTTP_ENABLED=false
PANACCESS_OPS_HTTP_ENABLED=false
CREATE_SUBSCRIBER_PUBLIC_ENABLED=true
DRF_THROTTLE_REGISTER=10/hour

# --- Caché ---
# CACHE_BACKEND=locmem

# --- CDN estáticos (opcional — docs/CDN_STATIC.md) ---
# CDN_STATIC_URL=https://cdn.ejemplo.com/static/

# --- Réplica PostgreSQL lectura (opcional — docs/DB_REPLICA_UBUNTU.md) ---
# DB_REPLICA_HOST=replica-host
# DB_REPLICA_PORT=5432

# --- Sentry (opcional) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Social login (roadmap #14: solo proveedores listados) ---
# google,facebook | google | vacio = no exige credenciales sociales al arrancar
SOCIAL_LOGIN_PROVIDERS=google,facebook
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=
