# Copiar a .env y completar valores reales

DEBUG=true
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de datos ---
# Dev (SQLite): no definir DB_ENGINE o dejar vacío
# Staging/prod (PostgreSQL):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=wind
# DB_USER=wind
# DB_PASSWORD=wind
# DB_HOST=localhost
# DB_PORT=5432
# DB_CONN_MAX_AGE=600
# Réplica lectura (Fase 4, opcional):
# DB_REPLICA_HOST=replica-host
# DB_REPLICA_PORT=5432

# --- Redis / Celery ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
CELERY_TASK_ALWAYS_EAGER=false

# --- PanAccess API ---
url_panaccess=
username=
password=
api_token=
salt=
hcId=
ENCRYPTION_KEY=

# --- Sesión PanAccess en Redis (multi-worker) ---
PANACCESS_SESSION_USE_REDIS=true
PANACCESS_SESSION_TTL_SECONDS=1500

# --- Circuit breaker (prod) ---
PANACCESS_CIRCUIT_BREAKER_ENABLED=true
PANACCESS_CB_FAILURE_THRESHOLD=5
PANACCESS_CB_RECOVERY_SECONDS=60

# --- Sync ---
CELERY_FULL_SYNC_HOUR=0
CELERY_FULL_SYNC_MINUTE=0
FULL_SYNC_HTTP_ENABLED=false

# --- Caché ---
# CACHE_BACKEND=locmem

# --- CDN estáticos (opcional) ---
# CDN_STATIC_URL=https://cdn.ejemplo.com/static/

# --- Sentry (opcional) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Social login ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=
