# =============================================================================
# Plantilla de entorno — STAGING / PRODUCCIÓN
# Copiar a .env y reemplazar todos los valores CHANGE_ME.
# Referencia canónica: appConfig.py (todas las variables están documentadas ahí).
# =============================================================================

# -----------------------------------------------------------------------------
# Django / seguridad HTTP
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_django_secret_key_min_50_chars
DEBUG=false
ALLOWED_HOSTS=windtv.wind.do,api.windtv.wind.do,localhost,127.0.0.1
PRODUCTION_HTTPS=true

# CORS: orígenes del frontend (sin barra final). Vacío en prod sin DEBUG → ninguno permitido.
CORS_ALLOWED_ORIGINS=https://windtv.wind.do
# CORS_DEV_DEFAULTS=true
# CORS_ALLOW_CREDENTIALS=false
# CORS_ALLOW_ALL_ORIGINS está prohibido por el código

# IPs permitidas para rutas sync/admin (vacío = sin filtro Django; usar también nginx)
SYNC_ADMIN_IP_ALLOWLIST=127.0.0.1,10.8.0.0/24

ENCRYPTION_KEY=CHANGE_ME_fernet_key_base64

# -----------------------------------------------------------------------------
# Base de datos (PostgreSQL en staging/prod)
# Sin DB_ENGINE → SQLite local (solo desarrollo)
# -----------------------------------------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=wind
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600
# DB_REPLICA_HOST=
# DB_REPLICA_PORT=

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PASSWORD=

# Opcional: URL única (prioridad sobre REDIS_HOST/PORT/DB)
# REDIS_URL=redis://:password@redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=

CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_POOL=prefork
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_WORKER_MAX_TASKS_PER_CHILD=100

CELERY_SYNC_MINUTES=10
CELERY_SMARTCARD_SYNC_MINUTES=10
CELERY_SYNC_LIMIT=200
CELERY_SYNC_QUEUE=sync_subscribers
CELERY_USE_CRONTAB=false

CELERY_FULL_SYNC_ENABLED=true
CELERY_FULL_SYNC_HOUR=0
CELERY_FULL_SYNC_MINUTE=0
CELERY_FULL_SYNC_TIME_LIMIT=3600
CELERY_FULL_SYNC_SOFT_TIME_LIMIT=3300

# Caché Django: vacío = Redis (REDIS_CACHE_DB); locmem = solo dev sin Redis
# CACHE_BACKEND=locmem

# -----------------------------------------------------------------------------
# PanAccess API (nombres legacy en minúsculas — requeridos)
# -----------------------------------------------------------------------------
url_panaccess=https://cv01.panaccess.com
username=CHANGE_ME
password=CHANGE_ME
api_token=CHANGE_ME
salt=_panaccess
hcId=CHANGE_ME
# Alias aceptado: hcid= (preferir hcId)

PANACCESS_SESSION_USE_REDIS=true
PANACCESS_SESSION_TTL_SECONDS=1500

PANACCESS_CIRCUIT_BREAKER_ENABLED=true
PANACCESS_CB_FAILURE_THRESHOLD=5
PANACCESS_CB_RECOVERY_SECONDS=60

PANACCESS_LOGIN_INFO_TRY_LIST_API=true
PANACCESS_LOGIN_INFO_CONCURRENCY=10
PANACCESS_LOGIN_INFO_PAGE_LIMIT=200
PANACCESS_LOGIN_INFO_DB_CHUNK=200
PANACCESS_LOGIN_DISCOVERY_MAX_CALLS=40

PANACCESS_SMARTCARD_SUBSCRIBER_MAX_PAGES=5
PANACCESS_SMARTCARD_PAGE_LIMIT=100
PANACCESS_SMARTCARD_SN_CONCURRENCY=5
PANACCESS_SMARTCARD_GLOBAL_FALLBACK=false
PANACCESS_SMARTCARD_SYNC_MAX_PAGES=15

# -----------------------------------------------------------------------------
# JWT / email / throttling DRF
# -----------------------------------------------------------------------------
JWT_USE_COOKIES=false
# JWT_AUTH_COOKIE=wind-auth
# JWT_AUTH_REFRESH_COOKIE=wind-refresh-token
JWT_ACCESS_MINUTES=15

ACCOUNT_EMAIL_VERIFICATION=mandatory
EMAIL_BACKEND=
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE_ME
EMAIL_HOST_PASSWORD=CHANGE_ME
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@windtv.wind.do

DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=600/minute
DRF_THROTTLE_PROFILE=120/minute
DRF_THROTTLE_SYNC_ADMIN=30/minute
DRF_THROTTLE_REGISTER=10/hour

# -----------------------------------------------------------------------------
# Login social (allauth)
# -----------------------------------------------------------------------------
SOCIAL_LOGIN_PROVIDERS=google,facebook

GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://api.windtv.wind.do/accounts/google/login/callback/

FACEBOOK_APP_ID=CHANGE_ME
FACEBOOK_APP_SECRET=CHANGE_ME
FACEBOOK_REDIRECT_URI=https://api.windtv.wind.do/accounts/facebook/login/callback/

# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Flags operativos (HTTP sync / registro / ops)
# -----------------------------------------------------------------------------
SYNC_HTTP_ASYNC=true
FULL_SYNC_HTTP_ENABLED=false
PANACCESS_OPS_HTTP_ENABLED=false
CREATE_SUBSCRIBER_PUBLIC_ENABLED=true

# -----------------------------------------------------------------------------
# Estáticos / observabilidad
# -----------------------------------------------------------------------------
# CDN_STATIC_URL=https://cdn.ejemplo.com/static/

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Pruebas de carga (scripts/load/locustfile.py — opcional)
# -----------------------------------------------------------------------------
# LOCUST_USERNAME=
# LOCUST_PASSWORD=
