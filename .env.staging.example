# Ejemplo para STAGING / PRE-PROD
# Objetivo: que `python manage.py check_deploy --strict` sea VERDE en un servidor tipo Ubuntu
# (en local Windows solo pasará si Redis está corriendo y accesible).
#
# IMPORTANTE:
# - NO pegues secretos reales aquí.
# - Copia este archivo a `.env` en el servidor y completa valores.
# - En producción real: usa valores finales (dominios, IP allowlist, Sentry, etc.).

# ============================================================================
# DJANGO / SEGURIDAD
# ============================================================================
DEBUG=false
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERAR_UN_SECRET_KEY_LARGO_Y_ALEATORIO
ALLOWED_HOSTS=api-staging.tudominio.com

# Frontend real (NO localhost). Debe ser https:// en Internet.
CORS_ALLOWED_ORIGINS=https://app-staging.tudominio.com

# En Ubuntu con Nginx+TLS (Certbot): obligatorio para pasar --strict
PRODUCTION_HTTPS=true

# Restringir rutas operativas de sync/admin (además de nginx allow/deny)
# Ejemplo: tu IP fija de oficina/VPN + localhost
SYNC_ADMIN_IP_ALLOWLIST=127.0.0.1,10.8.0.0/24

# Ejecutar sync HTTP como tareas async (no bloquear workers web)
SYNC_HTTP_ASYNC=true

# ============================================================================
# POSTGRESQL (staging/prod)
# ============================================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=wind
DB_USER=wind
DB_PASSWORD=CAMBIAR_EN_STAGING
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=600

# ============================================================================
# REDIS / CELERY
# ============================================================================
# Para pasar `check_deploy --strict` con PANACCESS_SESSION_USE_REDIS=true,
# Redis DEBE responder.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
# Si usas requirepass en redis.conf
# REDIS_PASSWORD=CAMBIAR_EN_STAGING

CELERY_TASK_ALWAYS_EAGER=false
CELERY_SYNC_QUEUE=sync_subscribers
CELERY_SYNC_MINUTES=10
CELERY_SMARTCARD_SYNC_MINUTES=10
CELERY_SYNC_LIMIT=200

# Full sync correctivo por Beat (no por HTTP en prod)
CELERY_FULL_SYNC_ENABLED=true
CELERY_FULL_SYNC_HOUR=0
CELERY_FULL_SYNC_MINUTE=0
FULL_SYNC_HTTP_ENABLED=false
PANACCESS_OPS_HTTP_ENABLED=false

# Sesión PanAccess compartida entre workers Gunicorn/Celery
PANACCESS_SESSION_USE_REDIS=true
PANACCESS_SESSION_TTL_SECONDS=1500

# Circuit breaker recomendado en staging/prod
PANACCESS_CIRCUIT_BREAKER_ENABLED=true
PANACCESS_CB_FAILURE_THRESHOLD=5
PANACCESS_CB_RECOVERY_SECONDS=60

# ============================================================================
# PANACCESS (completar con credenciales STAGING/PROD)
# ============================================================================
url_panaccess=
username=
password=
api_token=
salt=
hcId=
ENCRYPTION_KEY=

# ============================================================================
# REGISTRO PÚBLICO
# ============================================================================
CREATE_SUBSCRIBER_PUBLIC_ENABLED=true
DRF_THROTTLE_REGISTER=10/hour

# ============================================================================
# LOGIN SOCIAL (Google/Facebook)
# ============================================================================
SOCIAL_LOGIN_PROVIDERS=google,facebook
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api-staging.tudominio.com/accounts/google/login/callback/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://api-staging.tudominio.com/accounts/facebook/login/callback/

# ============================================================================
# OBSERVABILIDAD (recomendado)
# ============================================================================
# Para que `check_deploy --strict` no deje aviso en staging, setea DSN.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging
# SENTRY_TRACES_SAMPLE_RATE=0.1

